// gradient/magma — matplotlib's Magma polynomial fit.
fn magma(t: f32) -> vec3<f32> {
  let x = clamp(t, 0.0, 1.0);
  let c0 = vec3<f32>(-0.002136, -0.000749, -0.005386);
  let c1 = vec3<f32>(0.251747, 0.677947, 2.494598);
  let c2 = vec3<f32>(8.353717, -3.577719, 0.316484);
  let c3 = vec3<f32>(-27.667254, 14.264081, -13.649195);
  let c4 = vec3<f32>(52.170501, -27.943607, 12.944692);
  let c5 = vec3<f32>(-50.769282, 29.046080, 4.236323);
  let c6 = vec3<f32>(18.655243, -11.472252, -5.362077);
  return c0 + x * (c1 + x * (c2 + x * (c3 + x * (c4 + x * (c5 + x * c6)))));
}
