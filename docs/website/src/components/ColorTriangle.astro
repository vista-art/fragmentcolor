---
// <ColorTriangle /> — code on one side, triangle on the other. Nothing else.
//
// The code is rendered by Starlight's <Code> component (same Expressive
// Code path the rest of the page uses), so the theme — background, font,
// keyword colors — matches every other Snippet block on the article.
// A unique per-language identifier placeholder (`__CLR_RUST__` etc.) is
// what each code sample contains where the `[r, g, b, a]` literal would
// be; Shiki tokenises it as an identifier (single span). Right after
// mount, a small client script walks each rendered code block, finds
// the placeholder span, and replaces it with a `<button class="lit">`
// containing the live literal. Click that button and the browser's
// native color picker opens; pick a new color and the literal text
// rewrites in place AND the canvas re-renders. There is no second UI
// widget — the picker is a transient editor for the literal, the way a
// date picker is the editor for a date input. The reader's mental
// model stays clean: the code drives the triangle, period.
//
// Tabs use syncKey="lang" so the LangSelector + every Snippet on the
// page stay in step. Each language stores its own literal format
// (Rust/JS/Python/Swift use `[r, g, b, a]`; Kotlin uses
// `floatArrayOf(rf, gf, bf, af)`); the underlying RGBA value is shared
// so editing in one tab updates all.
//
// Render is single-shot (no RAF loop) — exactly what those three lines
// of code do when you actually run them.

import { Code, Tabs, TabItem } from "@astrojs/starlight/components";

interface Props {
  /** Initial RGBA color, each in [0, 1]. */
  initialColor?: [number, number, number, number];
  /** Pixel height for the canvas. */
  height?: string;
  /** Shader URL (defaults to the tutorial shader). */
  shaderUrl?: string;
}

const {
  initialColor = [0.95, 0.30, 0.42, 1.0],
  height = "360px",
  shaderUrl = "https://fragmentcolor.org/triangle.wgsl",
} = Astro.props;

// Per-language identifier placeholders. Each is a valid identifier in
// the language so Shiki tokenises it as one span; the client script
// then swaps that span for the interactive button.
const PLACEHOLDER = {
  rust: "__CLR_RUST__",
  js: "__CLR_JS__",
  py: "__CLR_PY__",
  swift: "__CLR_SWIFT__",
  kotlin: "__CLR_KT__",
};

const code = {
  rust: `let shader = Shader::new("${shaderUrl}")?;
shader.set("color", ${PLACEHOLDER.rust})?;
renderer.render(&shader, &target);`,
  js: `const shader = await Shader.fetch("${shaderUrl}");
shader.set("color", ${PLACEHOLDER.js});
renderer.render(shader, target);`,
  py: `shader = Shader.fetch("${shaderUrl}")
shader.set("color", ${PLACEHOLDER.py})
renderer.render(shader, target)`,
  swift: `let shader = try await Shader.fetch("${shaderUrl}")
shader.set("color", ${PLACEHOLDER.swift})
renderer.render(shader, target)`,
  kotlin: `val shader = Shader.fetch("${shaderUrl}")
shader.set("color", ${PLACEHOLDER.kotlin})
renderer.render(shader, target)`,
};
---

<div
  class="color-triangle not-content"
  data-rgba={JSON.stringify(initialColor)}
  data-shader-url={shaderUrl}
  data-height={height}>

  <div class="ct-grid">
    <div class="ct-code" data-placeholders={JSON.stringify(PLACEHOLDER)}>
      <Tabs syncKey="lang">
        <TabItem label="Rust"><Code code={code.rust} lang="rust" /></TabItem>
        <TabItem label="JavaScript"><Code code={code.js} lang="javascript" /></TabItem>
        <TabItem label="Python"><Code code={code.py} lang="python" /></TabItem>
        <TabItem label="Swift"><Code code={code.swift} lang="swift" /></TabItem>
        <TabItem label="Kotlin"><Code code={code.kotlin} lang="kotlin" /></TabItem>
      </Tabs>
    </div>
    <div class="ct-canvas-wrap" style={`height:${height};`}>
      <canvas></canvas>
      <div class="ct-err" role="alert"></div>
    </div>
  </div>

  <input class="ct-picker" type="color" aria-hidden="true" tabindex="-1" />
</div>

<style>
  .color-triangle {
    margin: 1.5rem 0;
    /* Container queries respond to the component's actual available
       width, not the viewport. Lets the layout collapse to a stack
       inside narrow column areas without chasing breakpoints. */
    container-type: inline-size;
    container-name: colortri;
  }
  .ct-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(240px, 1fr);
    gap: 1rem;
    align-items: stretch;
  }
  @container colortri (max-width: 720px) {
    .ct-grid { grid-template-columns: 1fr; }
    .ct-canvas-wrap { min-height: 260px; }
  }
  @supports not (container-type: inline-size) {
    @media (max-width: 900px) {
      .ct-grid { grid-template-columns: 1fr; }
      .ct-canvas-wrap { min-height: 260px; }
    }
  }

  /* The literal-as-button. Inherits Expressive Code's surrounding token
     color so it visually fits the highlighted line; a tiny color
     swatch glyph just before the literal text is the "I'm interactive"
     indicator that survives both light and dark themes. */
  .ct-code :global(button.lit) {
    display: inline;
    padding: 0;
    margin: 0;
    border: 0;
    background: transparent;
    color: inherit;
    font: inherit;
    cursor: pointer;
    text-decoration: none;
    border-radius: 2px;
  }
  .ct-code :global(button.lit:focus-visible) {
    outline: 2px solid var(--sl-color-text-accent, #9d7cd8);
    outline-offset: 2px;
  }
  .ct-code :global(.lit-swatch) {
    display: inline-block;
    width: 0.85em;
    height: 0.85em;
    margin-right: 0.35em;
    vertical-align: -0.1em;
    border-radius: 3px;
    /* Border uses currentColor at low alpha so it's visible against any
       Expressive Code theme background — light or dark. */
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.18),
      0 0 0 1px rgba(0, 0, 0, 0.45);
    transition: box-shadow 120ms ease;
  }
  .ct-code :global(button.lit:hover .lit-swatch),
  .ct-code :global(button.lit:focus-visible .lit-swatch) {
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.32),
      0 0 0 1px rgba(0, 0, 0, 0.65),
      0 0 0 3px rgba(157, 124, 216, 0.35);
  }

  .ct-canvas-wrap {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    background: linear-gradient(135deg, #0b1124 0%, #0f172a 60%, #111827 100%);
  }
  .ct-canvas-wrap canvas {
    width: 100%;
    height: 100%;
    display: block;
    background: transparent;
  }
  .ct-err {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    color: #fca5a5;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.8rem;
    background: rgba(15, 23, 42, 0.92);
    text-align: center;
    white-space: pre-wrap;
  }
  .ct-err.visible { display: flex; }

  .ct-picker {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
    margin: -1px;
    padding: 0;
    border: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }

  /* Briefly hide the placeholders if JS hasn't run yet — they're
     not human-readable. The script clears `data-pending` on first
     pass. Falls back to fully visible if the script never runs. */
  .ct-code[data-pending="1"] :global(.ec-line) { visibility: hidden; }
</style>

<script>
// @ts-nocheck
function rgbaToHex(rgba) {
  const c = (n) => Math.max(0, Math.min(255, Math.round(n * 255)))
    .toString(16).padStart(2, '0');
  return `#${c(rgba[0])}${c(rgba[1])}${c(rgba[2])}`;
}
function hexToRgb(hex) {
  const m = /^#([0-9a-f]{6})$/i.exec(hex.trim());
  if (!m) return [0, 0, 0];
  const n = parseInt(m[1], 16);
  return [((n >> 16) & 0xff) / 255, ((n >> 8) & 0xff) / 255, (n & 0xff) / 255];
}
function literalFor(lang, rgba) {
  const f2 = (n) => n.toFixed(2);
  const f1 = (n) => n.toFixed(1);
  if (lang === 'kotlin') {
    return `floatArrayOf(${f2(rgba[0])}f, ${f2(rgba[1])}f, ${f2(rgba[2])}f, ${f1(rgba[3])}f)`;
  }
  return `[${f2(rgba[0])}, ${f2(rgba[1])}, ${f2(rgba[2])}, ${f1(rgba[3])}]`;
}

function wireColorTriangle(root) {
  if (root.dataset.ctWired === '1') return;
  root.dataset.ctWired = '1';

  const rgba = JSON.parse(root.dataset.rgba || '[0.95,0.30,0.42,1.0]');
  const shaderUrl = root.dataset.shaderUrl || 'https://fragmentcolor.org/triangle.wgsl';
  const codeWrap = root.querySelector('.ct-code');
  const placeholders = JSON.parse(codeWrap.dataset.placeholders || '{}');
  const canvas = root.querySelector('canvas');
  const errEl = root.querySelector('.ct-err');
  const picker = root.querySelector('input.ct-picker');

  // Reverse-map: identifier text -> language key.
  const placeholderToLang = {};
  for (const [lang, ph] of Object.entries(placeholders)) {
    placeholderToLang[ph] = lang;
  }

  // Walk every text node under the rendered code and replace any
  // placeholder identifier with a <button>. Expressive Code splits
  // identifiers into single text nodes inside <span> wrappers, so a
  // textContent equality check is enough.
  codeWrap.dataset.pending = '1';
  const walker = document.createTreeWalker(codeWrap, NodeFilter.SHOW_TEXT);
  const replacements = [];
  let node;
  while ((node = walker.nextNode())) {
    const t = node.nodeValue;
    if (!t) continue;
    for (const [ph, lang] of Object.entries(placeholderToLang)) {
      if (t.includes(ph)) {
        replacements.push({ node, ph, lang });
        break;
      }
    }
  }
  for (const { node, ph, lang } of replacements) {
    const text = node.nodeValue;
    const idx = text.indexOf(ph);
    const before = text.slice(0, idx);
    const after = text.slice(idx + ph.length);
    const parent = node.parentNode;
    const button = document.createElement('button');
    button.className = 'lit';
    button.type = 'button';
    button.dataset.lang = lang;
    const swatch = document.createElement('span');
    swatch.className = 'lit-swatch';
    swatch.setAttribute('aria-hidden', 'true');
    swatch.style.backgroundColor = rgbaToHex(rgba);
    const litText = document.createElement('span');
    litText.className = 'lit-text';
    litText.textContent = literalFor(lang, rgba);
    button.append(swatch, litText);
    button.setAttribute('aria-label', `Edit color: ${litText.textContent}`);
    if (before) parent.insertBefore(document.createTextNode(before), node);
    parent.insertBefore(button, node);
    if (after) parent.insertBefore(document.createTextNode(after), node);
    parent.removeChild(node);
  }
  codeWrap.removeAttribute('data-pending');

  const lits = codeWrap.querySelectorAll('button.lit');
  let renderer, target, shader, started = false, stopped = false;

  function showError(msg) {
    if (!errEl) return;
    errEl.textContent = msg;
    errEl.classList.add('visible');
  }

  function applyToLiterals() {
    const hex = rgbaToHex(rgba);
    lits.forEach((btn) => {
      const text = literalFor(btn.dataset.lang, rgba);
      const litText = btn.querySelector('.lit-text');
      const swatch = btn.querySelector('.lit-swatch');
      if (litText) litText.textContent = text;
      if (swatch) swatch.style.backgroundColor = hex;
      btn.setAttribute('aria-label', `Edit color: ${text}`);
    });
    picker.value = hex;
  }

  function renderOnce() {
    if (!renderer || !target || !shader || stopped) return;
    try {
      shader.set('color', rgba);
      renderer.render(shader, target);
    } catch (e) {
      console.error('[ColorTriangle] render failed', e);
      showError(`render: ${e?.message || e}`);
    }
  }

  function applySize() {
    try {
      const dpr = Math.max(1, window.devicePixelRatio || 1);
      const w = Math.max(1, Math.floor(canvas.clientWidth * dpr));
      const h = Math.max(1, Math.floor(canvas.clientHeight * dpr));
      if (canvas.width !== w || canvas.height !== h) {
        canvas.width = w;
        canvas.height = h;
      }
      try { target?.resize([w, h]); } catch {}
    } catch {}
  }

  lits.forEach((btn) => {
    btn.addEventListener('click', () => {
      picker.value = rgbaToHex(rgba);
      const rect = btn.getBoundingClientRect();
      picker.style.position = 'absolute';
      picker.style.top = `${window.scrollY + rect.bottom}px`;
      picker.style.left = `${window.scrollX + rect.left}px`;
      picker.click();
    });
  });

  picker.addEventListener('input', (e) => {
    const rgb = hexToRgb(e.target.value);
    rgba[0] = rgb[0]; rgba[1] = rgb[1]; rgba[2] = rgb[2];
    applyToLiterals();
    renderOnce();
  });

  applyToLiterals();

  async function init() {
    if (started || stopped) return;
    started = true;
    try {
      const fc = await import('fragmentcolor');
      const wasmUrl = (await import('fragmentcolor/fragmentcolor_bg.wasm?url')).default;
      await fc.default({ module_or_path: wasmUrl });
      try { fc.Shader.setRegistry('/shaders/'); } catch {}
      renderer = new fc.Renderer();
      applySize();
      target = await renderer.createTarget(canvas);
      target.resize([canvas.width, canvas.height]);
      shader = await fc.Shader.fetch(shaderUrl);
      const ro = new ResizeObserver(() => { applySize(); renderOnce(); });
      ro.observe(canvas);
      renderOnce();
    } catch (e) {
      console.error('[ColorTriangle] init failed', e);
      showError(`init: ${e?.message || e}`);
    }
  }

  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries, obs) => {
      for (const entry of entries) {
        if (entry.isIntersecting) { obs.disconnect(); init(); break; }
      }
    }, { threshold: 0.01 });
    io.observe(root);
  } else {
    queueMicrotask(init);
  }
}

document.querySelectorAll('.color-triangle').forEach(wireColorTriangle);
</script>
