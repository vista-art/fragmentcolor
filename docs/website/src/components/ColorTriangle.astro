---
// <ColorTriangle /> — code on one side, triangle on the other. Nothing else.
//
// The code is rendered with the `[r, g, b, a]` literal as an inline
// button. Click it and the browser's native color picker opens; pick a
// new color and the literal text rewrites in place AND the canvas
// re-renders. There is no second UI widget — the picker is a transient
// editor for the literal, the way a date picker is the editor for a
// date input. The reader's mental model stays clean: the code drives
// the triangle, period.
//
// Renders a per-language code block under a <Tabs syncKey="lang">, so
// the LangSelector + every Snippet on the page stay in sync. Each
// language stores its own literal template (Rust/JS/Python/Swift use
// `[r, g, b, a]`; Kotlin uses `floatArrayOf(rf, gf, bf, af)`); the
// underlying RGBA value is shared so editing in one tab updates all.
//
// The shader is the same one the tutorial discusses
// (https://fragmentcolor.org/triangle.wgsl by default). Render is a
// single render-once-per-change — no RAF loop — matching what those
// three lines of code actually do.

import { Tabs, TabItem } from "@astrojs/starlight/components";

interface Props {
  /** Initial RGBA color, each in [0, 1]. */
  initialColor?: [number, number, number, number];
  /** Pixel height for the canvas. */
  height?: string;
  /** Shader URL (defaults to the tutorial shader). */
  shaderUrl?: string;
}

const {
  initialColor = [0.95, 0.30, 0.42, 1.0],
  height = "220px",
  shaderUrl = "https://fragmentcolor.org/triangle.wgsl",
} = Astro.props;

const fmt = (n: number) => n.toFixed(2);
const fmtA = (n: number) => n.toFixed(1);
const [r0, g0, b0, a0] = initialColor;
const arrLit = `[${fmt(r0)}, ${fmt(g0)}, ${fmt(b0)}, ${fmtA(a0)}]`;
const ktLit = `floatArrayOf(${fmt(r0)}f, ${fmt(g0)}f, ${fmt(b0)}f, ${fmtA(a0)}f)`;

// Each template embeds the exact <button class="lit" data-lang="..."> markup
// inline so syntax-class spans don't fight us. Keep these in sync with
// MultiCode's bodies in the tutorial.
const tpl = (lang: string, body: string) =>
  `<button class="lit" type="button" data-lang="${lang}">${
    lang === "kotlin" ? ktLit : arrLit
  }</button>`;

const code = {
  rust: `let shader = Shader::new("${shaderUrl}")?;
shader.set("color", ${tpl("rust", "")})?;
renderer.render(&shader, &target);`,
  js: `const shader = await Shader.fetch("${shaderUrl}");
shader.set("color", ${tpl("js", "")});
renderer.render(shader, target);`,
  py: `shader = Shader.fetch("${shaderUrl}")
shader.set("color", ${tpl("py", "")})
renderer.render(shader, target)`,
  swift: `let shader = try await Shader.fetch("${shaderUrl}")
shader.set("color", ${tpl("swift", "")})
renderer.render(shader, target)`,
  kotlin: `val shader = Shader::fetch("${shaderUrl}")
shader.set("color", ${tpl("kotlin", "")})
renderer.render(shader, target)`,
};
---

<div
  class="color-triangle not-content"
  data-rgba={JSON.stringify(initialColor)}
  data-shader-url={shaderUrl}
  data-height={height}>

  <div class="ct-grid">
    <div class="ct-code">
      <Tabs syncKey="lang">
        <TabItem label="Rust"><pre><code set:html={code.rust} /></pre></TabItem>
        <TabItem label="JavaScript"><pre><code set:html={code.js} /></pre></TabItem>
        <TabItem label="Python"><pre><code set:html={code.py} /></pre></TabItem>
        <TabItem label="Swift"><pre><code set:html={code.swift} /></pre></TabItem>
        <TabItem label="Kotlin"><pre><code set:html={code.kotlin} /></pre></TabItem>
      </Tabs>
    </div>
    <div class="ct-canvas-wrap">
      <canvas></canvas>
      <div class="ct-err" role="alert"></div>
    </div>
  </div>

  <input class="ct-picker" type="color" aria-hidden="true" tabindex="-1" />
</div>

<style>
  .color-triangle {
    margin: 1.5rem 0;
  }
  .ct-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(220px, 1fr);
    gap: 1rem;
    align-items: stretch;
  }
  @media (max-width: 720px) {
    .ct-grid {
      grid-template-columns: 1fr;
    }
  }

  .ct-code :global(pre) {
    margin: 0;
    padding: 0.85rem 1rem;
    background: #282a36;
    color: #f8f8f2;
    border-radius: 6px;
    overflow-x: auto;
    font-family: var(--__sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    font-size: 0.85rem;
    line-height: 1.55;
  }
  .ct-code :global(code) {
    background: transparent;
    padding: 0;
    color: inherit;
  }

  /* The literal is a button styled to look like inline code. Hover and
     focus get a subtle hint that it's interactive. */
  .ct-code :global(button.lit) {
    display: inline;
    padding: 0;
    margin: 0;
    border: 0;
    background: transparent;
    color: #ffb86c;
    font: inherit;
    cursor: pointer;
    text-decoration: underline dotted rgba(255, 184, 108, 0.6);
    text-underline-offset: 3px;
  }
  .ct-code :global(button.lit:hover),
  .ct-code :global(button.lit:focus-visible) {
    color: #ffd29a;
    text-decoration-color: rgba(255, 210, 154, 1);
    outline: none;
  }

  .ct-canvas-wrap {
    position: relative;
    height: 100%;
    min-height: 220px;
    border-radius: 8px;
    overflow: hidden;
    background: linear-gradient(135deg, #0b1124 0%, #0f172a 60%, #111827 100%);
  }
  .ct-canvas-wrap canvas {
    width: 100%;
    height: 100%;
    display: block;
    background: transparent;
  }
  .ct-err {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    color: #fca5a5;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.8rem;
    background: rgba(15, 23, 42, 0.92);
    text-align: center;
    white-space: pre-wrap;
  }
  .ct-err.visible { display: flex; }

  /* Hidden color picker — clicked programmatically when a literal is clicked. */
  .ct-picker {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
    margin: -1px;
    padding: 0;
    border: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }
</style>

<script>
// @ts-nocheck
function rgbaToHex(rgba) {
  const c = (n) => Math.max(0, Math.min(255, Math.round(n * 255)))
    .toString(16).padStart(2, '0');
  return `#${c(rgba[0])}${c(rgba[1])}${c(rgba[2])}`;
}
function hexToRgb(hex) {
  const m = /^#([0-9a-f]{6})$/i.exec(hex.trim());
  if (!m) return [0, 0, 0];
  const n = parseInt(m[1], 16);
  return [((n >> 16) & 0xff) / 255, ((n >> 8) & 0xff) / 255, (n & 0xff) / 255];
}
function literalFor(lang, rgba) {
  const f2 = (n) => n.toFixed(2);
  const f1 = (n) => n.toFixed(1);
  if (lang === 'kotlin') {
    return `floatArrayOf(${f2(rgba[0])}f, ${f2(rgba[1])}f, ${f2(rgba[2])}f, ${f1(rgba[3])}f)`;
  }
  return `[${f2(rgba[0])}, ${f2(rgba[1])}, ${f2(rgba[2])}, ${f1(rgba[3])}]`;
}

document.querySelectorAll('.color-triangle').forEach((root) => {
  if (root.dataset.ctWired === '1') return;
  root.dataset.ctWired = '1';

  const rgba = JSON.parse(root.dataset.rgba || '[0.95,0.30,0.42,1.0]');
  const shaderUrl = root.dataset.shaderUrl || 'https://fragmentcolor.org/triangle.wgsl';
  const canvas = root.querySelector('canvas');
  const errEl = root.querySelector('.ct-err');
  const picker = root.querySelector('input.ct-picker');
  const lits = root.querySelectorAll('button.lit');

  let renderer, target, shader, started = false, stopped = false;

  function showError(msg) {
    if (!errEl) return;
    errEl.textContent = msg;
    errEl.classList.add('visible');
  }

  function applyToLiterals() {
    lits.forEach((btn) => {
      btn.textContent = literalFor(btn.dataset.lang, rgba);
    });
    picker.value = rgbaToHex(rgba);
  }

  function renderOnce() {
    if (!renderer || !target || !shader || stopped) return;
    try {
      shader.set('color', rgba);
      renderer.render(shader, target);
    } catch (e) {
      console.error('[ColorTriangle] render failed', e);
      showError(`render: ${e?.message || e}`);
    }
  }

  function applySize() {
    try {
      const dpr = Math.max(1, window.devicePixelRatio || 1);
      const w = Math.max(1, Math.floor(canvas.clientWidth * dpr));
      const h = Math.max(1, Math.floor(canvas.clientHeight * dpr));
      if (canvas.width !== w || canvas.height !== h) {
        canvas.width = w;
        canvas.height = h;
      }
      try { target?.resize([w, h]); } catch {}
    } catch {}
  }

  // Wire literal clicks → open the hidden picker.
  lits.forEach((btn) => {
    btn.addEventListener('click', () => {
      picker.value = rgbaToHex(rgba);
      // Position the picker near the clicked literal so the native picker
      // pops next to it on browsers that anchor it to the input.
      const rect = btn.getBoundingClientRect();
      picker.style.position = 'absolute';
      picker.style.top = `${window.scrollY + rect.bottom}px`;
      picker.style.left = `${window.scrollX + rect.left}px`;
      picker.click();
    });
  });

  picker.addEventListener('input', (e) => {
    const rgb = hexToRgb(e.target.value);
    rgba[0] = rgb[0]; rgba[1] = rgb[1]; rgba[2] = rgb[2];
    applyToLiterals();
    renderOnce();
  });

  // Set initial display values (in case the prefilled markup drifts).
  applyToLiterals();

  async function init() {
    if (started || stopped) return;
    started = true;
    try {
      const fc = await import('fragmentcolor');
      const wasmUrl = (await import('fragmentcolor/fragmentcolor_bg.wasm?url')).default;
      await fc.default({ module_or_path: wasmUrl });
      try { fc.Shader.setRegistry('/shaders/'); } catch {}
      renderer = new fc.Renderer();
      applySize();
      target = await renderer.createTarget(canvas);
      target.resize([canvas.width, canvas.height]);
      shader = await fc.Shader.fetch(shaderUrl);
      const ro = new ResizeObserver(() => { applySize(); renderOnce(); });
      ro.observe(canvas);
      renderOnce();
    } catch (e) {
      console.error('[ColorTriangle] init failed', e);
      showError(`init: ${e?.message || e}`);
    }
  }

  // Lazy-load on first viewport intersection.
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries, obs) => {
      for (const entry of entries) {
        if (entry.isIntersecting) { obs.disconnect(); init(); break; }
      }
    }, { threshold: 0.01 });
    io.observe(root);
  } else {
    queueMicrotask(init);
  }
});
</script>
